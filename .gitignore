# Python
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# ========================================
# ORGANIZED PROJECT STRUCTURE
# ========================================

# Data Directory (contains sensitive/trading data)
data/
!data/.gitkeep

# Logs Directory (application logs)
logs/
!logs/.gitkeep

# Models Directory (ML models - can be large)
models/
!models/.gitkeep

# Config Directory (keep templates, ignore actual config)
config/.env
config/config.yaml
!config/.env.example
!config/example.env

# Documentation (keep all docs)
!docs/

# Scripts (keep all scripts)
!scripts/

# ========================================
# DEVELOPMENT & TESTING
# ========================================

# Test cache
.pytest_cache/
.coverage
htmlcov/
.tox/

# Jupyter Notebook
.ipynb_checkpoints

# ========================================
# PRODUCTION & DEPLOYMENT
# ========================================

# Docker
.dockerignore

# Kubernetes secrets (if any)
k8s/*secret*.yaml

# ========================================
# SENSITIVE DATA PATTERNS
# ========================================

# API Keys and secrets
*API_KEY*
*SECRET*
*TOKEN*
*PASSWORD*

# Personal data
*user*
*email*

# Financial data (be careful with these)
*balance*
*pnl*
*profit*
